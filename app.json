{
  "expo": {
    "name": "Digital Haute",
    "slug": "digital-haute",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "digitalhaute",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.digitalhaute.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.digitalhaute.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Digital Haute to access your camera to scan product labels and take product photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Digital Haute to access your photos to add product images."
        }
      ],
      "expo-apple-authentication"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f03b5ad1-14ee-4ef0-a372-9c472e26d3aa"
    },
    "extra": {
      "eas": {
        "projectId": "f03b5ad1-14ee-4ef0-a372-9c472e26d3aa"
      }
    }
  }
}
