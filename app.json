{
  "expo": {
    "name": "Digital Haute",
    "slug": "digital-haute",
    "owner": "jasonhckim",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "digitalhaute",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.digitalhaute.iosapp",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.digitalhaute.iosapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#FAF6F1"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Digital Haute to access your camera to scan product labels and take product photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Digital Haute to access your photos to add product images."
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#C4A265"
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3e0b9dd8-9ee0-45c9-b735-3dda6a11dc5c"
    },
    "extra": {
      "eas": {
        "projectId": "3e0b9dd8-9ee0-45c9-b735-3dda6a11dc5c"
      }
    }
  }
}
