# Server Configuration
EXPO_PUBLIC_DOMAIN=localhost:5000

# PostgreSQL Database URL (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Firebase Admin Service Account (JSON string — for server-side auth)
# Paste the full contents of your firebase-service-account.json here as one line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# OpenAI API (for label scanning feature - server-side only)
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini API (server-side only — used for virtual try-on)
GEMINI_API_KEY=your-gemini-api-key-here

# Firebase Client Configuration (get from Firebase Console)
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# Google Sign-In (Firebase Auth — requires a development/production native build, not Expo Go)
# 1) Firebase Console → Authentication → Sign-in method → enable Google.
# 2) Web client ID: Firebase Console → Project settings → Your apps → Web app (or Authentication → Google → Web SDK configuration).
#    Use the OAuth 2.0 client ID ending in .apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# 3) iOS reversed client ID for URL scheme (app.config.js / native prebuild). From Firebase iOS app
#    GoogleService-Info.plist key REVERSED_CLIENT_ID, e.g. com.googleusercontent.apps.xxxxx
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-ios-reversed-client-id
# Android: add your release/debug SHA-1 in Firebase → Project settings → Android app (required for Google Sign-In on device).

# Optional — team invite emails via Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM="Digital Haute <onboarding@yourdomain.com>"
# Used in join-team HTML and invite emails (defaults to "Digital Haute")
APP_PUBLIC_NAME=Digital Haute

# RevenueCat Webhook Secret (optional — for server-side subscription sync)
REVENUECAT_WEBHOOK_SECRET=

# Shopify Integration (optional)
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_CONNECTED_AT=
